{
  "name": "srv",
  "version": "1.0.0",
  "private": true,

  
"dependencies": {
  "@sap/cds": "^9",
  "@cap-js/sqlite": "^2.4",
  "sqlite3": "^5",
  "@sap-cloud-sdk/http-client": "^4.7.0",
  "@sap-cloud-sdk/util": "^4.7.0",
  "@sap/low-code-event-handler": "^1.2.5",
  "@sap/xsenv": ">=3.3.2 <3.3.3",
  "@sap/xssec": "^4.13.0",
  "passport": "^0.7.0"
}
,

  "scripts": {
    "start": "cds-serve"
  },

 
"cds": {
  "requires": {
    "db": {
      "kind": "sqlite",
      "use": "sqlite3",
      "credentials": {
        "url": ":memory:"
      }
    },
    "auth": {
      "[development]": {
        "kind": "dummy"
      },
      "[production]": {
        "kind": "xsuaa"
      }
    }
  }
}
