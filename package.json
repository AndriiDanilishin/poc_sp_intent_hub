{
  "name": "poc_sp_intent_hub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch"
  },
  "dependencies": {
    "@sap/cds": "^9.9.1",
    "@cap-js/sqlite": "^2.4.0",
    "@sap/xssec": "^4.13.0",
    "express": "^4",
    "@sap-cloud-sdk/http-client": "^4.7.0",
    "@sap-cloud-sdk/util": "^4.7.0"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.9.2",
    "cds-plugin-ui5": "^0.13.0"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/sourcing-requests"
  ],
  "cds": {
    "requires": {
      "[development]": {
        "db": { "kind": "sqlite", "credentials": { "url": ":memory:" } },
        "auth": "dummy"
      },
      "[production]": {
        "auth": "xsuaa",
        "db": { "kind": "sqlite", "credentials": { "url": ":memory:" } }
      }
    }
  }
}