{
  "name": "poc_sp_intent_hub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "cds build --production",
    "test": "node --test"
  },
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/http-client": "^4.7.0",
    "@sap-cloud-sdk/util": "^4.7.0",
    "@sap/cds": "^9.9.1",
    "@sap/xssec": "^4.13.0",
    "express": "^4",
    "hana-cli": "^4.202605.2"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.9.2",
    "@cap-js/sqlite": "^2.4.0",
    "cds-plugin-ui5": "^0.13.0",
    "@cap-js/cds-test": "^1"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/sourcing-requests"
  ],
  "cds": {
    "requires": {
      "db": {
        "kind": "sql",
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "url": ":memory:"
          }
        },
        "[production]": {
          "kind": "hana-cloud",
          "deploy-format": "hdbtable"
        },
        "[hybrid]": {
          "kind": "hana-cloud",
          "deploy-format": "hdbtable"
        }
      },
      "auth": {
        "[development]": {
          "kind": "dummy"
        },
        "[production]": {
          "kind": "xsuaa"
        }
      }
    },
    "hana": {
      "deploy-format": "hdbtable"
    }
  }
}
